{
  "manifest_version": 3,
  "name": "OnScreen AI DOM Bridge",
  "description": "Sends visible webpage DOM element map to OnScreen AI Assistant for accurate prompts.",
  "version": "0.1.0",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "https://*/*",
    "http://*/*"
  ],
  "action": {
    "default_title": "Send DOM map",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
